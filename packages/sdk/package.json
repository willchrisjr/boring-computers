{
	"name": "boring-computers-sdk",
	"version": "0.1.0",
	"description": "Effect-native TypeScript client for boring computers — on-demand Firecracker microVMs you can hand to an AI.",
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/michaelshimeles/boring-computers.git",
		"directory": "packages/sdk"
	},
	"homepage": "https://github.com/michaelshimeles/boring-computers#readme",
	"keywords": [
		"firecracker",
		"microvm",
		"sandbox",
		"ai",
		"agents",
		"effect"
	],
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"prettier": "@boring/prettier-config",
	"scripts": {
		"check": "tsc --noEmit",
		"build": "tsc",
		"test": "vitest run",
		"lint": "prettier --check .",
		"format": "prettier --write .",
		"prepublishOnly": "npm run build"
	},
	"dependencies": {
		"effect": "^3.12.0",
		"@effect/platform": "^0.96.0"
	},
	"devDependencies": {
		"typescript": "^6.0.3",
		"@boring/typescript-config": "*",
		"@boring/prettier-config": "*",
		"@types/node": "^24",
		"vitest": "^4.1.8"
	}
}
