{
	"extends": "@boring/typescript-config/base.json",
	"compilerOptions": {
		"module": "NodeNext",
		"moduleResolution": "nodenext",
		"target": "ESNext",
		"lib": ["ESNext"],
		"types": ["node"],
		"declaration": true,
		"sourceMap": true,
		"outDir": "dist",
		"rootDir": "src"
	},
	"include": ["src"],
	"exclude": ["dist", "node_modules"]
}
